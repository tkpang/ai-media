# AI Media Workspace - Environment Configuration Template
# Copy this file to .env and fill in your actual API credentials
# DO NOT commit .env to git (it contains secrets!)

# ============================================================
# Banana Pro (Image Generation)
# ============================================================

# API Provider: APIYI, LaoZhang, or custom
BANANA_PRO_PROVIDER=APIYI

# API Key from your provider dashboard
BANANA_PRO_API_KEY=sk-your-api-key-here

# Base URL (get from provider documentation)
# APIYI: https://api.apiyi.com (example - verify actual endpoint)
# LaoZhang: https://api.laozhang.ai (example - verify actual endpoint)
# XAIS Web: https://xais1.dchai.cn (requires BANANA_PRO_MODE=web)
BANANA_PRO_BASE_URL=https://api.provider.com

# Integration mode:
# - api: Gemini/OpenAI-style HTTP API providers
# - web: xais web automation flow (/xais/xtokenLogin -> workerTaskStart -> workerTaskWait)
BANANA_PRO_MODE=api

# Default route for image generation (2K_2 or 2K_5 recommended for cost)
BANANA_PRO_DEFAULT_ROUTE=2K_2

# Default aspect ratio
BANANA_PRO_DEFAULT_ASPECT_RATIO=1:1

# ============================================================
# Seedance 2.0 (Video Generation) - Add when ready
# ============================================================

# SEEDANCE_API_KEY=sk-your-seedance-key-here
# SEEDANCE_BASE_URL=https://api.seedance-provider.com
# SEEDANCE_DEFAULT_DURATION=10
# SEEDANCE_DEFAULT_RESOLUTION=1080p

# ============================================================
# Output Configuration
# ============================================================

# Directory for generated media files
OUTPUT_DIR=./outputs

# Create subdirectories by date (true/false)
OUTPUT_USE_DATE_FOLDERS=false

# Image format (png/jpg/webp)
OUTPUT_IMAGE_FORMAT=png

# Video format (mp4/webm)
OUTPUT_VIDEO_FORMAT=mp4

# ============================================================
# Cost Tracking
# ============================================================

# Enable cost tracking and logging (true/false)
ENABLE_COST_TRACKING=true

# Cost tracking log file
COST_LOG_FILE=./outputs/cost_log.json

# Budget alert threshold (USD)
BUDGET_ALERT_THRESHOLD=50.00

# ============================================================
# Performance Settings
# ============================================================

# Request timeout (seconds)
REQUEST_TIMEOUT=120

# Max concurrent requests for batch processing
MAX_CONCURRENT_REQUESTS=5

# Enable caching of API responses (true/false)
ENABLE_CACHING=false

# Cache directory
CACHE_DIR=./cache

# Cache TTL (seconds)
CACHE_TTL=3600

# ============================================================
# Logging
# ============================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/ai_media.log

# Enable verbose API logging (true/false)
VERBOSE_API_LOGGING=false

# ============================================================
# Development Settings
# ============================================================

# Development mode (enables extra logging and validation)
DEV_MODE=false

# Skip API calls in development (use mock responses)
USE_MOCK_RESPONSES=false

# Test mode (prevents actual charges)
TEST_MODE=false
